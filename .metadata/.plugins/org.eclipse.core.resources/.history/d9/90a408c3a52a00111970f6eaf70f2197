package pages;

import org.openqa.selenium.By;

public class HomePage extends BasePage {
	
	private By firstProduct = By.cssSelector("a.full-unstyled-link");
	
	public void clickFirstProduct() {
		click(firstProduct);
	}

	public boolean isHomePageLoaded() {
	    return waitUtils.waitForElementVisible(firstProduct).isDisplayed();
	}

}
